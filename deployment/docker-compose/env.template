# SECURITY WARNING: Always set NODE_ENV=production in production environments
# to prevent information disclosure vulnerabilities
NODE_ENV=development
LOG_LEVEL=info

ALLOWED_ORIGINS=

# Docker image tag — https://hub.docker.com/r/pipeshubai/pipeshub-ai
# - latest: larger image with a pre-downloaded embedding model; use for air-gapped or VPC deployments without internet
# - slim: smaller image; use with API-based embeddings, or when the model can be downloaded after deploy
IMAGE_TAG=slim

SECRET_KEY=your_random_encryption_secret_key

# Use Public URL (HTTPs only) to open web page
FRONTEND_PUBLIC_URL=

ARANGO_PASSWORD=your_arangodb_password

REDIS_PASSWORD=

MONGO_USERNAME=admin
MONGO_PASSWORD=your_mongodb_password
# If MongoDB crash-loops with a segfault (exit 139) on a newer host kernel,
# try the rseq tunable first so the supported MongoDB version can stay pinned.
# MONGO_GLIBC_TUNABLES=glibc.pthread.rseq=1
# Fallback only: pin an older image. MongoDB 8.x data is not readable by 7.x,
# so wipe the mongo volume before downgrading.
# MONGO_IMAGE_TAG=8.0.17
#
# MongoDB resource limits. Defaults target the quickstart minimum: a 16 GB-class
# shared Docker host running MongoDB alongside the app, Qdrant, graph DB, Redis,
# and optional broker services. WiredTiger's upstream default can reserve several
# GB on such hosts, so the default cache is capped at 1 GB and the container gets
# 2 GB to leave room for process overhead. Increase both on larger/dedicated
# hosts; avoid decreasing below 1 GB unless this is a very small dev workload.
# MONGO_CACHE_GB=1
# MONGO_MEMORY_LIMIT=2G

QDRANT_API_KEY=your_qdrant_api_key

# KV store: use "redis" or "etcd"
KV_STORE_TYPE=redis

# Message broker: "kafka" (default) or "redis" (uses Redis Streams)
MESSAGE_BROKER=kafka
# When using Kafka, enable the kafka profile to start Kafka + Zookeeper containers:
#   COMPOSE_PROFILES=kafka
# When using Redis Streams, leave COMPOSE_PROFILES unset to skip Kafka/Zookeeper entirely.
COMPOSE_PROFILES=kafka
# Redis Streams settings (only used when MESSAGE_BROKER=redis)
REDIS_STREAMS_MAXLEN=10000

# Consumer settings
# Max times a message can be delivered before being dead-lettered (default: 10)
# MAX_DELIVERY_ATTEMPTS=10

# MCP OAuth scopes (comma-separated)
MCP_SCOPES=openid,profile,email,offline_access,semantic:write,conversation:write,conversation:chat,kb:read,team:read,user:read,config:read


# Worker counts
INDEXING_UVICORN_WORKERS=1
DOCLING_UVICORN_WORKERS=1
LOCAL_DOCLING_PARSE_WORKERS=1
PDF_OCR_DETECTION_WORKERS=1

# Embedding server (local HuggingFace / SentenceTransformer models)
EMBEDDING_SERVER_URL=http://localhost:8002

# Docker json-file log rotation (used by compose logging.driver options)
LOG_MAX_SIZE=20m
LOG_MAX_FILE=15

# Indexing concurrency
MAX_CONCURRENT_PARSING=5
MAX_CONCURRENT_INDEXING=7
MAX_PENDING_INDEXING_TASKS=40

# LLM row processing threshold
MAX_TABLE_ROWS_FOR_LLM=1000

# Excel table size limits
EXCEL_MAX_TABLE_ROWS_TO_INDEX=20000
EXCEL_HEADER_GENERATION_SAMPLE_SCAN_LIMIT=500

# SAML SP Entity ID (Issuer) — must match the Audience URI in your IdP (e.g. Okta "Audience URI (SP Entity ID)").
# Defaults to FRONTEND_PUBLIC_URL if set, otherwise 'pipeshub'.
SAML_SP_ENTITY_ID=