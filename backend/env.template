PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3001

SECRET_KEY=my-secret

FRONTEND_PUBLIC_URL=http://localhost:3001
QUERY_BACKEND=http://localhost:8000
CONNECTOR_BACKEND=http://localhost:8088
CONNECTOR_PUBLIC_BACKEND=
INDEXING_BACKEND=http://localhost:8091

# Key-Value Store Configuration
# KV_STORE_TYPE: 'redis' or 'etcd' (default: etcd)
KV_STORE_TYPE=etcd

# ETCD Configuration (used when KV_STORE_TYPE=etcd)
ETCD_URL=http://localhost:2379
ETCD_HOST=localhost
ETCD_TIMEOUT=5000

ARANGO_URL=http://localhost:8529
ARANGO_DB_NAME=es
ARANGO_USERNAME=root
ARANGO_PASSWORD=your_password

KAFKA_BROKERS=localhost:9092
# KAFKA_SSL=true
# KAFKA_SASL_MECHANISM=scram-sha-512      # Options: plain, scram-sha-256, scram-sha-512
# KAFKA_USERNAME=
# KAFKA_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD:-}@localhost:6379
# Redis KV store settings (used when KV_STORE_TYPE=redis)
REDIS_DB=0
REDIS_TIMEOUT=10000
REDIS_KV_PREFIX=pipeshub:kv:

MONGO_URI=mongodb://admin:password@localhost:27017/
MONGO_DB_NAME=enterprise-search

QDRANT_API_KEY=your_qdrant_secret_api_key
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_PORT=6333

OLLAMA_API_URL=http://localhost:11434

ACCESS_TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h

NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# MCP OAuth scopes (comma-separated)
MCP_SCOPES=openid,profile,email,offline_access,semantic:write,conversation:write,conversation:chat,kb:read,team:read,user:read,config:read

# Message broker: "kafka" (default) or "redis" (uses Redis Streams)
MESSAGE_BROKER=kafka
# When using Kafka, enable the kafka profile to start Kafka + Zookeeper containers:
#   COMPOSE_PROFILES=kafka
# When using Redis Streams, leave COMPOSE_PROFILES unset to skip Kafka/Zookeeper entirely.
COMPOSE_PROFILES=kafka
# Redis Streams settings (only used when MESSAGE_BROKER=redis)
REDIS_STREAMS_MAXLEN=10000

# Consumer settings
# Max times a message can be delivered before being dead-lettered (default: 10)
# MAX_DELIVERY_ATTEMPTS=10

# SAML SP Entity ID (Issuer) — must match the Audience URI configured in your IdP.
# Defaults to FRONTEND_PUBLIC_URL if set, otherwise 'pipeshub'.
# SAML_SP_ENTITY_ID=

