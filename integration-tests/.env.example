# -----------------------------------------------------------------------------
# .env — only the environment selector (no secrets here)
# -----------------------------------------------------------------------------
# Use exactly one. All credentials go in the corresponding file below.
PIPESHUB_TEST_ENV=local
# PIPESHUB_TEST_ENV=prod

# -----------------------------------------------------------------------------
# Credentials live in:
#   .env.local  when PIPESHUB_TEST_ENV=local
#   .env.prod   when PIPESHUB_TEST_ENV=prod
# Do not commit .env.local or .env.prod — they contain secrets.
# See env.local.template for full variable names.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# AI model provider integration tests
# (response-validation/ai-model-providers/integration_test_ai_model_providers.py)
# Positive tests skip automatically when a provider's key(s) are unset.
# -----------------------------------------------------------------------------
# OpenAI (provider id: openAI) — also used by session ai_models_configured fixture
# (seeds LLM + cloud embedding for indexing-heavy ITs)
TEST_OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini in provider tests, gpt-5.4-nano in indexing fixture)
TEST_OPENAI_LLM_MODEL=
# Optional embedding override (default: text-embedding-3-small in indexing fixture)
TEST_OPENAI_EMBEDDING_MODEL=

# Google Gemini (provider id: gemini)
TEST_GEMINI_API_KEY=
TEST_GEMINI_LLM_MODEL=

# Azure OpenAI (provider id: azureOpenAI)
TEST_AZURE_OPENAI_API_KEY=
TEST_AZURE_OPENAI_ENDPOINT=
TEST_AZURE_OPENAI_DEPLOYMENT_NAME=
TEST_AZURE_OPENAI_MODEL=

# Groq (provider id: groq)
TEST_GROQ_API_KEY=
TEST_GROQ_LLM_MODEL=

# Optional: non-admin user for admin-gate negative test (session JWT, not OAuth)
# PIPESHUB_TEST_NON_ADMIN_EMAIL=
# PIPESHUB_TEST_NON_ADMIN_PASSWORD=
