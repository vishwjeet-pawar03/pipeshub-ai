# Copy to .env.prod and fill in. Used when .env has PIPESHUB_TEST_ENV=prod
# Do not commit .env.prod — it contains secrets.

# Remote test environment (test.pipeshub.com)
PIPESHUB_BASE_URL=https://test.pipeshub.com

# Prod auth: OAuth2 client_credentials (required for remote runs)
CLIENT_ID=
CLIENT_SECRET=

# Existing user id in the same org. Share/unshare tests skip when empty.
PIPESHUB_TEST_SHARE_TARGET_USER_ID=

# Neo4j Aura (driver uses TEST_NEO4J_* only)
TEST_NEO4J_URI=
TEST_NEO4J_USERNAME=
TEST_NEO4J_PASSWORD=
TEST_NEO4J_DATABASE=neo4j

# Storage credentials — only for connectors you run
S3_ACCESS_KEY=
S3_SECRET_KEY=
GCS_SERVICE_ACCOUNT_JSON=
AZURE_BLOB_CONNECTION_STRING=
AZURE_FILES_CONNECTION_STRING=

# AI models — required for the indexing e2e pipeline tests. The session fixture
# POSTs an OpenAI LLM and cloud embedding to
# /api/v1/configurationManager/ai-models/providers at session start and DELETEs
# them at session end.
TEST_OPENAI_API_KEY=
# Optional override (default: gpt-5.4-nano)
TEST_OPENAI_LLM_MODEL=
# Optional override (default: text-embedding-3-small)
TEST_OPENAI_EMBEDDING_MODEL=

# Provider integration tests (integration_test_ai_model_providers.py) — skip when unset
TEST_GEMINI_API_KEY=
TEST_GEMINI_LLM_MODEL=
TEST_AZURE_OPENAI_API_KEY=
TEST_AZURE_OPENAI_ENDPOINT=
TEST_AZURE_OPENAI_DEPLOYMENT_NAME=
TEST_AZURE_OPENAI_MODEL=
TEST_GROQ_API_KEY=
TEST_GROQ_LLM_MODEL=
# PIPESHUB_TEST_NON_ADMIN_EMAIL=
# PIPESHUB_TEST_NON_ADMIN_PASSWORD=

# Jira Cloud (API token auth)
JIRA_TEST_BASE_URL=
JIRA_TEST_EMAIL=
JIRA_TEST_API_TOKEN=
CONFLUENCE_TEST_BASE_URL=
CONFLUENCE_TEST_EMAIL=
CONFLUENCE_TEST_API_TOKEN=
CONFLUENCE_TEST_SPACE_KEY=
LINEAR_TEST_API_TOKEN=
LINEAR_TEST_TEAM_IDS=