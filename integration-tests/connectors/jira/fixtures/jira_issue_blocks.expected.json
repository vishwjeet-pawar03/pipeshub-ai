      "code_metadata": null,
      "comments": [],
      "data": "# [KAN-13] # User Profile Page Fails to Save Changes\nUsers with **Multi-Factor Authentication (MFA)** enabled are unable to sign in. The login request returns **HTTP 500**, preventing access to the application.",
      "file_metadata": null,
      "format": "markdown",
      "image_metadata": null,
      "index": 0,
      "link_metadata": null,
      "links": null,
      "list_metadata": null,
      "media_metadata": null,
